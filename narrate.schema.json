{
  "$ref": "#/definitions/Config",
  "definitions": {
    "Config": {
      "type": "object",
      "properties": {
        "tts": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "gemini",
                "elevenlabs",
                "os",
                "mock"
              ],
              "default": "gemini"
            },
            "voice": {
              "type": "string",
              "default": "Kore"
            },
            "model": {
              "type": "string"
            },
            "apiKeyEnv": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "default": {
            "provider": "gemini",
            "voice": "Kore"
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "dir": {
              "type": "string",
              "default": "out"
            },
            "width": {
              "type": "number",
              "default": 1440
            },
            "height": {
              "type": "number",
              "default": 900
            },
            "fps": {
              "type": "number",
              "default": 25
            },
            "format": {
              "type": "string",
              "enum": [
                "mp4",
                "webm"
              ],
              "default": "mp4"
            },
            "crf": {
              "type": "number",
              "default": 18
            }
          },
          "additionalProperties": false,
          "default": {
            "dir": "out",
            "width": 1440,
            "height": 900,
            "fps": 25,
            "format": "mp4",
            "crf": 18
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
