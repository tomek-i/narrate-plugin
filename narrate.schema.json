{
  "$ref": "#/definitions/Config",
  "definitions": {
    "Config": {
      "type": "object",
      "properties": {
        "tts": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "gemini",
                "elevenlabs",
                "os",
                "mock"
              ],
              "default": "os"
            },
            "gemini": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "voice": {
                  "type": "string",
                  "default": "Kore"
                },
                "model": {
                  "type": "string",
                  "default": "gemini-2.5-flash-preview-tts"
                },
                "apiKeyEnv": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "elevenlabs": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "voice": {
                  "type": "string",
                  "default": "9BWtsMINqrJLrRacOk9x"
                },
                "model": {
                  "type": "string",
                  "default": "eleven_multilingual_v2"
                },
                "apiKeyEnv": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "default": {}
            }
          },
          "additionalProperties": false,
          "default": {
            "provider": "os"
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "dir": {
              "type": "string",
              "default": "out"
            },
            "width": {
              "type": "number",
              "default": 1440
            },
            "height": {
              "type": "number",
              "default": 900
            },
            "fps": {
              "type": "number",
              "default": 25
            },
            "format": {
              "type": "string",
              "enum": [
                "mp4",
                "webm"
              ],
              "default": "mp4"
            },
            "crf": {
              "type": "number",
              "default": 16
            }
          },
          "additionalProperties": false,
          "default": {
            "dir": "out",
            "width": 1440,
            "height": 900,
            "fps": 25,
            "format": "mp4",
            "crf": 16
          }
        },
        "overlay": {
          "type": "object",
          "properties": {
            "cursor": {
              "type": "boolean",
              "default": true
            },
            "highlight": {
              "type": "boolean",
              "default": true
            },
            "style": {
              "type": "string",
              "enum": [
                "ring",
                "glow",
                "spotlight"
              ],
              "default": "ring"
            },
            "holdMs": {
              "type": "number",
              "minimum": 0,
              "default": 3000
            },
            "color": {
              "type": "string",
              "default": "#6366f1"
            }
          },
          "additionalProperties": false,
          "default": {
            "cursor": true,
            "highlight": true,
            "style": "ring",
            "holdMs": 3000,
            "color": "#6366f1"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
