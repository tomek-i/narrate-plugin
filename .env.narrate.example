# Copy to `.env.narrate` (gitignored) and fill in the key for the provider you use.
# Keys are namespaced with NARRATE_ to avoid collisions with your app's own keys.

# Gemini (https://aistudio.google.com/apikey) — default provider
NARRATE_GEMINI_API_KEY=

# ElevenLabs (https://elevenlabs.io) — set tts.provider="elevenlabs" in narrate.config.json
NARRATE_ELEVENLABS_API_KEY=

# Want a custom var name instead? Set tts.apiKeyEnv in narrate.config.json
# to the name of any env var and narrate will read the key from there.
